// ── KEYWORD MATCHING ──────────────────────────────────────────────────────────

function matchQuery(raw) {
  const q = raw.toLowerCase().trim();

  const matchers = {
    "generative-ai": [
      "generative","gen ai","genai","llm adoption","enterprise ai","gpt","chatgpt",
      "copilot","openai","anthropic","claude","gemini","foundation model","large language",
      "ai adoption","ai strategy","ai enterprise","ai productivity","ai governance"
    ],
    "data-platform": [
      "data platform","data platforms","lakehouse","snowflake","databricks","consolidation",
      "data warehouse","data lake","iceberg","delta lake","hadoop","etl","elt","kafka",
      "data stack","data infrastructure","data architecture","data engineering","data mesh",
      "data","analytics platform","redpanda","confluent","dbt","fivetran","airbyte"
    ],
    "cloud-fintech": [
      "cloud migration","fintech","finance","banking","financial services","bank",
      "dora","fca","open banking","baas","banking as a service","cloud fintech",
      "cloud banking","core banking","hybrid cloud","multi-cloud","cloud strategy",
      "cloud infrastructure","cloud adoption","cloud native","aws","azure","gcp",
      "cloud","migration strategy","digital banking"
    ],
    "open-source-llm": [
      "open source","open-source","llama","mistral","hugging face","huggingface",
      "fine-tuning","fine tuning","lora","qlora","quantisation","quantization",
      "open weight","open model","phi","gemma","falcon","community model",
      "on-device","edge ai","edge inference","self-hosted","local llm","oss llm",
      "open llm","model fine","domain specific model"
    ]
  };

  // Score each category by counting keyword hits
  let bestKey = null;
  let bestScore = 0;

  for (const [key, keywords] of Object.entries(matchers)) {
    let score = 0;
    for (const kw of keywords) {
      if (q.includes(kw)) {
        // Longer matches score higher
        score += kw.split(" ").length;
      }
    }
    if (score > bestScore) {
      bestScore = score;
      bestKey = key;
    }
  }

  return bestKey;
}

// ── RENDER ────────────────────────────────────────────────────────────────────

function renderResults(key) {
  const d = INSIGHTS[key];
  if (!d) return renderNotFound();

  const now = new Date();
  const timeStr = now.toLocaleTimeString('en-GB', { hour:'2-digit', minute:'2-digit' });

  let cardsHtml = d.cards.map((c, i) => `
    <div class="insight-card ${c.wide ? 'wide' : ''}" style="animation-delay:${(i+2)*0.07}s">
      <div class="card-icon-wrap" style="background:${c.iconBg}">${c.icon}</div>
      <div class="card-label" style="color:${c.labelColor}">${c.label}</div>
      <div class="card-title">${c.title}</div>
      <div class="card-body">${c.body}</div>
      <span class="card-stat" style="background:${c.statBg};color:${c.statColor}">${c.stat}</span>
    </div>
  `).join('');

  let signalsHtml = d.signals.map(s => `
    <div class="signal">
      <span class="signal-dot" style="background:${s.color}"></span>
      ${s.label}
    </div>
  `).join('');

  return `
    <div class="results-header">
      <div>
        <div class="results-query">Analysis for</div>
        <div class="results-title">${d.title}</div>
      </div>
      <div class="results-meta">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        Synthesised · ${timeStr}
      </div>
    </div>

    <div class="signal-bar" style="animation-delay:.05s">
      <div class="signal-bar-title">Macro Signals Detected</div>
      <div class="signals">${signalsHtml}</div>
    </div>

    <div class="section-label" style="animation-delay:.1s">Key Insights</div>
    <div class="results-grid">${cardsHtml}</div>
  `;
}

function renderNotFound() {
  return `
    <div class="empty-state">
      <div class="empty-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#EA4335" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h3>No data for this query</h3>
      <p>Try one of the suggested topics below the search bar,<br>or refine your query to match a tracked trend.</p>
    </div>
  `;
}

function showLoader() {
  return `
    <div class="loader">
      <div class="loader-dots">
        <div class="loader-dot"></div>
        <div class="loader-dot"></div>
        <div class="loader-dot"></div>
      </div>
      <div class="loader-text">Aggregating macro signals…</div>
      <div class="loader-sub">Synthesising industry intelligence</div>
    </div>
  `;
}

// ── ACTIONS ───────────────────────────────────────────────────────────────────

const emptyState = document.getElementById('empty-state');
const resultsContent = document.getElementById('results-content');

function runAnalysis(rawQuery) {
  emptyState.style.display = 'none';
  resultsContent.style.display = 'block';
  resultsContent.innerHTML = showLoader();

  // Fake async for polish
  setTimeout(() => {
    const key = matchQuery(rawQuery);
    resultsContent.innerHTML = renderResults(key);
    window.scrollTo({ top: document.querySelector('#results-area').offsetTop - 80, behavior: 'smooth' });
  }, 900);
}

// Search button
document.getElementById('search-btn').addEventListener('click', () => {
  const q = document.getElementById('search-input').value.trim();
  if (!q) return;
  updateChips(null);
  runAnalysis(q);
});

// Enter key
document.getElementById('search-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    const q = e.target.value.trim();
    if (!q) return;
    updateChips(null);
    runAnalysis(q);
  }
});

// Chips
function updateChips(activeKey) {
  document.querySelectorAll('.chip').forEach(c => {
    c.classList.toggle('active', c.dataset.query === activeKey);
  });
}

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const key = chip.dataset.query;
    const label = chip.textContent.trim();
    document.getElementById('search-input').value = label;
    updateChips(key);
    runAnalysis(label);
  });
});
</script>
